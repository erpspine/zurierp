              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tenantToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"CUST-0001\",\n  \"lead_id\": \"LD-0001\",\n  \"full_name\": \"John A. Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phone_whatsapp\": \"+971555111222\",\n  \"country\": \"UAE\",\n  \"city\": \"Dubai\",\n  \"lead_source\": \"Website\",\n  \"travel_start_date\": \"2026-06-15\",\n  \"travel_end_date\": \"2026-06-22\",\n  \"number_of_days\": 8,\n  \"number_of_nights\": 7,\n  \"number_of_pax\": 4,\n  \"adults\": 2,\n  \"children\": 1,\n  \"infants\": 1,\n  \"preferred_destinations\": [\"Dubai\", \"Abu Dhabi\", \"Sharjah\"],\n  \"trip_type\": \"Family Leisure\",\n  \"residency_type\": \"Tourist\",\n  \"budget_range\": \"Premium\",\n  \"estimated_budget_amount\": 9200,\n  \"preferred_vehicle\": \"Luxury SUV\",\n  \"accommodation_type\": \"Resort\",\n  \"room_preference\": \"Suite\",\n  \"meal_plan\": \"Full Board\",\n  \"activities_interested_in\": [\"Desert Safari\", \"Yacht Cruise\", \"City Tour\"],\n  \"special_interests\": \"Photography and culture\",\n  \"dietary_requirement\": \"Halal vegetarian options\",\n  \"language_preference\": \"English\",\n  \"guide_preference\": \"Arabic-speaking\",\n  \"lead_status\": \"contacted\",\n  \"assigned_sales_person_id\": {{assignedSalesPersonId}},\n  \"priority\": \"high\",\n  \"follow_up_date\": \"2026-05-22\",\n  \"follow_up_time\": \"14:00\",\n  \"next_action\": \"Send revised quotation\",\n  \"quotation_status\": \"sent\",\n  \"probability_of_winning\": 75,\n  \"client_request_summary\": \"Luxury family trip with premium add-ons.\",\n  \"passport_visa_notes\": \"Visa docs under processing.\",\n  \"internal_sales_notes\": \"Strong potential, follow up in 2 days.\",\n  \"payment_special_conditions\": \"40% advance, balance before arrival.\",\n  \"uploaded_documents\": [\"https://example.com/docs/passport-john.pdf\", \"https://example.com/docs/visa-form.pdf\"]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/app/leads/{{leadId}}",
              "host": [
